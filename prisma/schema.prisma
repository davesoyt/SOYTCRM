generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  password           String?
  role               String              @default("member")
  color              String              @default("#6366f1")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tasks              Task[]
  segmentAssignments SegmentAssignment[]
  notifications      Notification[]
}

model Company {
  id           String     @id @default(cuid())
  name         String
  domain       String?
  industry     String?
  size         String?
  website      String?
  customFields String     @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  contacts      Contact[]
  opportunities Opportunity[]
  activities    Activity[]
  tasks        Task[]

  @@index([name])
  @@index([domain])
  @@index([createdAt])
}

model Contact {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  email        String       @unique
  phone        String?
  title        String?
  leadScore    Int          @default(0)
  linkedin     String?
  enriched     Boolean      @default(false)
  customFields String       @default("{}")
  street       String?
  city         String?
  state        String?
  zip          String?
  country      String?
  lat          Float?
  lng          Float?
  companyId    String?
  company      Company?     @relation(fields: [companyId], references: [id])
  opportunities Opportunity[]
  activities    Activity[]
  enrollments   Enrollment[]
  tasks        Task[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([companyId])
  @@index([leadScore])
  @@index([firstName])
  @@index([lastName])
  @@index([phone])
  @@index([createdAt])
}

model Opportunity {
  id         String     @id @default(cuid())
  name       String
  value      Float
  stage      String     @default("Prospect")
  ownerId    String?
  contactId  String?
  contact    Contact?   @relation(fields: [contactId], references: [id])
  companyId  String?
  company    Company?   @relation(fields: [companyId], references: [id])
  pipelineId String?
  pipeline   Pipeline?  @relation(fields: [pipelineId], references: [id])
  activities Activity[]
  tasks      Task[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  closedAt   DateTime?

  @@index([contactId])
  @@index([companyId])
  @@index([pipelineId])
  @@index([stage])
  @@index([name])
  @@index([createdAt])
  @@index([closedAt])
  @@map("Opportunity")
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String
  stages    String   @default("[]")
  isDefault Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  opportunities Opportunity[]

  @@index([isDefault, order])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  createdAt DateTime @default(now())

  @@index([contactId, createdAt])
  @@index([companyId, createdAt])
  @@index([opportunityId, createdAt])
  @@index([type, createdAt])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  segmentId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([createdAt])
}

model Sequence {
  id           String                @id @default(cuid())
  name         String
  description  String?
  trigger      String                @default("Manual")
  isActive     Boolean               @default(false)
  nodesJson    String                @default("[]")
  edgesJson    String                @default("[]")
  steps        SequenceStep[]
  enrollments  Enrollment[]
  segmentLinks SegmentWorkflowLink[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([isActive, createdAt])
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  dayOffset  Int
  subject    String
  body       String
  order      Int
  assigneeId String?
  segmentId  String?

  @@index([sequenceId, order])
}

model Segment {
  id              String                @id @default(cuid())
  name            String
  description     String?
  objectType      String                @default("contact")
  filtersJson     String                @default("[]")
  listType        String                @default("dynamic")
  memberIds       String                @default("[]")
  lastEvaluatedAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  assignments     SegmentAssignment[]
  workflowLinks   SegmentWorkflowLink[]
  campaigns       Campaign[]

  @@index([objectType, updatedAt])
}

model Campaign {
  id             String    @id @default(cuid())
  name           String
  subject        String    @default("")
  body           String    @default("")
  segmentId      String?
  segment        Segment?  @relation(fields: [segmentId], references: [id])
  status         String    @default("draft")
  sentAt         DateTime?
  scheduledAt    DateTime?
  recipientCount Int       @default(0)
  openCount      Int       @default(0)
  clickCount     Int       @default(0)
  fromName       String    @default("")
  fromEmail      String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([segmentId, status])
  @@index([createdAt])
}

model SegmentAssignment {
  id         String   @id @default(cuid())
  segmentId  String
  segment    Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([segmentId, userId])
}

model CRMSettings {
  id       String  @id @default("default")
  name     String  @default("CRM")
  logoData String? // base64 data URL
}

model CustomObjectDef {
  id         String               @id @default(cuid())
  name       String
  pluralName String
  slug       String               @unique
  icon       String               @default("Box")
  color      String               @default("#6366f1")
  createdAt  DateTime             @default(now())
  fields     FieldDefinition[]
  records    CustomObjectRecord[]

  @@index([createdAt])
}

model FieldDefinition {
  id               String           @id @default(cuid())
  objectType       String?          // 'contact' | 'company' | 'opportunity' | null (for custom)
  customObjectDefId String?
  customObjectDef  CustomObjectDef? @relation(fields: [customObjectDefId], references: [id], onDelete: Cascade)
  key              String
  label            String
  fieldType        String           @default("text") // text|number|date|email|phone|url|select|boolean
  selectOptions    String           @default("[]")   // JSON array
  required         Boolean          @default(false)
  isPrimary        Boolean          @default(false)
  order            Int              @default(0)
  isBuiltIn        Boolean          @default(false)
  hidden           Boolean          @default(false)
  createdAt        DateTime         @default(now())

  @@index([objectType, hidden, order])
  @@index([customObjectDefId, hidden, order])
}

model CustomObjectRecord {
  id            String          @id @default(cuid())
  objectDefId   String
  objectDef     CustomObjectDef @relation(fields: [objectDefId], references: [id], onDelete: Cascade)
  data          String          @default("{}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([objectDefId, createdAt])
}

/// Idempotency log for Stripe webhook processing.
model ProcessedStripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}

/// Configurable inbound webhook → object field mapping.
model WebhookIntegration {
  id             String   @id @default(cuid())
  name           String
  provider       String   @default("stripe") // stripe
  enabled        Boolean  @default(true)
  targetKind     String   // standard | custom
  targetSlug     String   // contact | company | opportunity | custom object slug
  eventTypes     String   @default("[]")    // JSON string[]
  fieldMappings  String   @default("[]")    // JSON WebhookFieldMapping[]
  upsertFieldKey String   @default("")      // object field used to find/update existing rows
  webhookSecret  String   @default("")      // Stripe signing secret (whsec_...)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deliveries ProcessedWebhookDelivery[]

  @@index([provider, enabled])
}

model ProcessedWebhookDelivery {
  id            String             @id @default(cuid())
  integrationId String
  integration   WebhookIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  eventId       String             // evt_...
  eventType     String
  processedAt   DateTime           @default(now())

  @@unique([integrationId, eventId])
}

model ObjectRelationship {
  id         String   @id @default(cuid())
  fromObject String
  fromField  String
  toObject   String
  toField    String
  relType    String   @default("one_to_many")
  label      String   @default("")
  createdAt  DateTime @default(now())

  @@index([fromObject, toObject])
}

model SegmentWorkflowLink {
  id             String    @id @default(cuid())
  segmentId      String
  segment        Segment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  sequenceId     String
  sequence       Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  assignedUserId String?
  createdAt      DateTime  @default(now())

  @@unique([segmentId, sequenceId])
}

model Enrollment {
  id            String           @id @default(cuid())
  contactId     String?
  contact       Contact?         @relation(fields: [contactId], references: [id])
  companyId     String?
  opportunityId String?
  recordType    String           @default("contact") // contact | company | opportunity | <customObjectSlug>
  recordId      String           @default("")        // primary record id (mirrors contactId/companyId/opportunityId or custom record id)
  recordLabel   String           @default("")        // human display name at enrollment time
  sequenceId    String
  sequence      Sequence         @relation(fields: [sequenceId], references: [id])
  currentStep   Int              @default(0)
  currentNodeId String?          // canvas node id currently executing / waiting on
  resumeAt      DateTime?        // when a wait step releases
  contextJson   String           @default("{}") // formMode, segmentId, etc.
  active        Boolean          @default(true)
  startedAt     DateTime         @default(now())
  completedAt   DateTime?
  runLogs       WorkflowRunLog[]

  @@index([sequenceId, active])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([recordType, recordId])
  @@index([resumeAt])
  @@index([startedAt])
}

model WorkflowRunLog {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stepIndex    Int        @default(0)
  nodeType     String     // 'enrolled' | 'email' | 'task' | 'wait' | 'condition' | 'completed' | etc.
  nodeLabel    String
  dataJson     String     @default("{}") // JSON: rich data about what happened
  status       String     @default("completed") // 'running' | 'completed' | 'skipped'
  executedAt   DateTime   @default(now())

  @@index([enrollmentId, executedAt])
}

model Form {
  id          String   @id @default(cuid())
  name        String
  description String?
  objectTypes String   @default("[]")   // JSON: string[] of objectType slugs/ids
  layoutJson  String   @default("[]")   // JSON: FormSection[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  name        String
  description String?
  configJson  String   @default("{}") // JSON: ReportConfig
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
